# 复制为 .env 并填写。.env 已在 .gitignore 中，不会被提交。

# ── 币安 Futures 下单 ──────────────────────────────────────────────
BINANCE_API_KEY=your_key_here
BINANCE_API_SECRET=your_secret_here
# 强烈建议先 testnet 验证（true），确认无误再切 false 上主网
BINANCE_TESTNET=true

# ── 数据服务 exchange-gateway ─────────────────────────────────────
# 取数依赖（参考客户端 + proto）已内置进本包，无需 exchange-gateway 仓库；只需本机装 grpcurl。
# klines + features：新 aggtrade-kline-gateway（8778）。dev 本机端口为 127.0.0.1:8878
KLINE_TARGET=13.231.65.185:8778
# funding：旧 market gateway（8777，8778 不提供 funding）
FUNDING_TARGET=13.231.65.185:8777
# 每次拉多少根 1d bars（8778 上限 300）
KLINE_LOOKBACK=300

# ── universe = CMC Top N（universe.mode=cmc_top_n 时需要）──────────
CMC_API_KEY=
CMC_TOP_N=10

# ── 风控（可选，留空用默认）───────────────────────────────────────
LEVERAGE=1
MAX_SINGLE_WEIGHT=0.40
MIN_ORDER_NOTIONAL=20.0
MAX_DRAWDOWN_HALT=-0.20
LIMIT_ORDER_TIMEOUT=60

# ── 日度调仓时间（UTC）────────────────────────────────────────────
REBALANCE_HOUR_UTC=0
REBALANCE_MINUTE_UTC=5
