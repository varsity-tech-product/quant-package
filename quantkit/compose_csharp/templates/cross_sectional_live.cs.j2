 * Rule:         rank by composite score ({{ weighting_mode }} weighted), pick
 *               {%- if rank_mode == "N" %} top/bot {{ rank_value|int }} {% else %} top/bot {{ rank_value }}% {% endif %}, strategy_type={{ strategy_type }}.
