    /// Extra columns default to double.NaN until a feature value is merged in.
    /// </summary>
    public class LiveFactorBar
    {
        public decimal Open;
        public decimal High;
        public decimal Low;
        public decimal Close;
        public decimal Volume;
        public double TakerBuyVolume       = double.NaN;
        public double TakerSellVolume      = double.NaN;
        public double TakerBuyQuoteVolume  = double.NaN;
        public double TakerSellQuoteVolume = double.NaN;
        public double TakerBuyTrades       = double.NaN;
        public double TakerSellTrades      = double.NaN;
        public double QuoteVolume          = double.NaN;
        public double OpenInterestOpen              = double.NaN;
        public double OpenInterestHigh              = double.NaN;
        public double OpenInterestLow               = double.NaN;
        public double OpenInterestClose             = double.NaN;
        public double FundingRateOpen               = double.NaN;
        public double FundingRateHigh               = double.NaN;
        public double FundingRateLow                = double.NaN;
        public double FundingRateClose              = double.NaN;
        public double GlobalAccountLongPercent      = double.NaN;
        public double GlobalAccountShortPercent     = double.NaN;
        public double GlobalAccountLongShortRatio   = double.NaN;
        public double TopPositionLongPercent        = double.NaN;
        public double TopPositionShortPercent       = double.NaN;
        public double TopPositionLongShortRatio     = double.NaN;
        public double TopAccountLongPercent         = double.NaN;
        public double TopAccountShortPercent        = double.NaN;
        public double TopAccountLongShortRatio      = double.NaN;
        public double LiquidationLongUsd            = double.NaN;
        public double LiquidationShortUsd           = double.NaN;
        public double BinancePremiumIndexOpen       = double.NaN;
        public double BinancePremiumIndexHigh       = double.NaN;
        public double BinancePremiumIndexLow        = double.NaN;
        public double BinancePremiumIndexClose      = double.NaN;
    }

    public class {{ class_name }} : QCAlgorithm
    {
        // ── Composite weights (one per factor) ──
        private static readonly double[] _weights = new double[] { {{ weights|join(", ") }} };

        // ── Selection rule ──
        private const string RankMode = "{{ rank_mode }}";          // "N" or "percent"
        private const double RankValue = {{ rank_value }};
        private const string StrategyType = "{{ strategy_type }}";   // long_only / short_only / neutral
        private const int RebalanceBars = {{ rebalance_bars }};
        private const bool SubscribeFeatures = {{ "true" if subscribe_features else "false" }};

        // ── Tradable universe (lowercase pairs) ──
        private static readonly string[] AllSymbols = new string[] {
            {%- for s in all_symbols %}
            "{{ s }}"{% if not loop.last %},{% endif %}
            {%- endfor %}
        };

        // pair (UPPER) → tradable CryptoFuture Symbol (target of SetHoldings/Liquidate)
        private readonly Dictionary<string, Symbol> _tradable = new Dictionary<string, Symbol>();
        // pair (UPPER) → close-price ring buffer
        private readonly Dictionary<string, Queue<double>> _priceBuf = new Dictionary<string, Queue<double>>();
        // pair (UPPER) → merged OHLCV+feature bar
        private readonly Dictionary<string, LiveFactorBar> _merged = new Dictionary<string, LiveFactorBar>();

        // ── Factor states (one Dictionary<pair, State> per factor) ──
        {%- for f in factors %}
        private readonly Dictionary<string, FactorState_F{{ f.factor_index }}> _f{{ f.factor_index }}States = new Dictionary<string, FactorState_F{{ f.factor_index }}>();
        {%- endfor %}

        private int _barsSinceRebalance = 0;
        private int _maxRequiredBars = 1;

        public override void Initialize()
        {
            SetStartDate({{ start_year }}, {{ start_month }}, {{ start_day }});
            // Live mode runs forward from "now"; no SetEndDate.
            SetCash({{ initial_cash }});
            SetTimeZone(TimeZones.Utc);

            var resolution = Resolution.{{ lean_resolution }};

            // Determine max factor lookback (per-factor PRICE_WINDOW_EXPR).
            {%- for f in factors %}
            {
                var s = new FactorState_F{{ f.factor_index }}();
                s.InitParams(this);
                _maxRequiredBars = Math.Max(_maxRequiredBars, s.RequiredBars());
            }
            {%- endfor %}

            foreach (var sym in AllSymbols)
            {
                var pair = sym.ToUpperInvariant();

                // Tradable security — orders route to Binance USD-M via binance_direct.
                var future = AddCryptoFuture(pair, resolution, Market.Binance, fillForward: true);
                _tradable[pair] = future.Symbol;

                {%- if subscribe_features %}
                // Feature stream carrier (DQH reflection-fills it from market_features).
                AddData<MatchXKlineWithCoinglassBar>(pair, resolution);
                {%- endif %}

                _priceBuf[pair] = new Queue<double>();
                _merged[pair] = new LiveFactorBar();
                {%- for f in factors %}
                {
                    var s = new FactorState_F{{ f.factor_index }}();
                    s.InitParams(this);
                    _f{{ f.factor_index }}States[pair] = s;
                }
                {%- endfor %}
            }

            // Best-effort warm-up. NOTE: binance_direct has no history provider, so
            // this does not backfill; buffers fill forward from live bars.
            var warmupBars = _maxRequiredBars + 5;
            SetWarmUp(warmupBars, resolution);

            Log($"[INIT] {{ class_name }} factors={{ factors|length }} symbols={AllSymbols.Length} " +
                $"weights=[{string.Join(",", _weights)}] rankMode={RankMode} rankValue={RankValue} " +
                $"strategyType={StrategyType} rebalanceBars={RebalanceBars} features={SubscribeFeatures} warmupBars={warmupBars}");
            {%- for f in factors %}
            Log("[INIT] factor#{{ f.factor_index }} type={{ f.factor_type }} formula={{ f.factor_formula }}");
            {%- endfor %}
        }

{%- if subscribe_features %}
        private static double FeatVal(decimal d)
        {
            // MissingValue sentinel → NaN so the per-factor NaN guard skips the symbol.
            return d <= MatchXKlineWithCoinglassBar.MissingValue + 1m ? double.NaN : (double)d;
        }

        private void MergeFeature(string pair, MatchXKlineWithCoinglassBar f)
        {
            if (!_merged.TryGetValue(pair, out var m)) return;
            m.TakerBuyVolume       = FeatVal(f.TakerBuyVolume);
            m.TakerSellVolume      = FeatVal(f.TakerSellVolume);
            m.TakerBuyQuoteVolume  = FeatVal(f.TakerBuyQuoteVolume);
            m.TakerSellQuoteVolume = FeatVal(f.TakerSellQuoteVolume);
            m.TakerBuyTrades       = FeatVal(f.TakerBuyTrades);
            m.TakerSellTrades      = FeatVal(f.TakerSellTrades);
            var tbq = FeatVal(f.TakerBuyQuoteVolume);
            var tsq = FeatVal(f.TakerSellQuoteVolume);
            m.QuoteVolume = (double.IsNaN(tbq) || double.IsNaN(tsq)) ? double.NaN : tbq + tsq;
            m.OpenInterestOpen            = FeatVal(f.OpenInterestOpen);
            m.OpenInterestHigh            = FeatVal(f.OpenInterestHigh);
            m.OpenInterestLow             = FeatVal(f.OpenInterestLow);
            m.OpenInterestClose           = FeatVal(f.OpenInterestClose);
            m.FundingRateOpen             = FeatVal(f.FundingRateOpen);
            m.FundingRateHigh             = FeatVal(f.FundingRateHigh);
            m.FundingRateLow              = FeatVal(f.FundingRateLow);
            m.FundingRateClose            = FeatVal(f.FundingRateClose);
            m.GlobalAccountLongPercent    = FeatVal(f.GlobalAccountLongPercent);
            m.GlobalAccountShortPercent   = FeatVal(f.GlobalAccountShortPercent);
            m.GlobalAccountLongShortRatio = FeatVal(f.GlobalAccountLongShortRatio);
            m.TopPositionLongPercent      = FeatVal(f.TopPositionLongPercent);
            m.TopPositionShortPercent     = FeatVal(f.TopPositionShortPercent);
            m.TopPositionLongShortRatio   = FeatVal(f.TopPositionLongShortRatio);
            m.TopAccountLongPercent       = FeatVal(f.TopAccountLongPercent);
            m.TopAccountShortPercent      = FeatVal(f.TopAccountShortPercent);
            m.TopAccountLongShortRatio    = FeatVal(f.TopAccountLongShortRatio);
            m.LiquidationLongUsd          = FeatVal(f.LiquidationLongUsd);
            m.LiquidationShortUsd         = FeatVal(f.LiquidationShortUsd);
            m.BinancePremiumIndexOpen     = FeatVal(f.BinancePremiumIndexOpen);
            m.BinancePremiumIndexHigh     = FeatVal(f.BinancePremiumIndexHigh);
            m.BinancePremiumIndexLow      = FeatVal(f.BinancePremiumIndexLow);
            m.BinancePremiumIndexClose    = FeatVal(f.BinancePremiumIndexClose);
        }
{%- endif %}

        public override void OnData(Slice slice)
        {
{%- if subscribe_features %}
            // Merge latest features first so the kline tick sees current feature columns.
            foreach (var kv in slice.Get<MatchXKlineWithCoinglassBar>())
                MergeFeature(kv.Key.Value.ToUpperInvariant(), kv.Value);
{%- endif %}

            // Drive on price bars: update merged OHLCV, push close, advance factor state.
            foreach (var kv in slice.Bars)
            {
                var pair = kv.Key.Value.ToUpperInvariant();
                if (!_priceBuf.ContainsKey(pair)) continue;
                var bar = kv.Value;

                var m = _merged[pair];
                m.Open = bar.Open; m.High = bar.High; m.Low = bar.Low; m.Close = bar.Close; m.Volume = bar.Volume;

                var pBuf = _priceBuf[pair];
                pBuf.Enqueue((double)bar.Close);
                if (pBuf.Count > _maxRequiredBars) pBuf.Dequeue();

                {%- for f in factors %}
                if (_f{{ f.factor_index }}States.TryGetValue(pair, out var st{{ f.factor_index }}))
                    st{{ f.factor_index }}.UpdateBar(m, _maxRequiredBars);
                {%- endfor %}
            }

            if (IsWarmingUp) return;

            _barsSinceRebalance++;
            if (_barsSinceRebalance < RebalanceBars) return;
            _barsSinceRebalance = 0;

            Rebalance();
        }

        private void Rebalance()
        {
            // ── Step 1: collect raw factor signals for every warmed-up symbol ──
            var rawByFactor = new Dictionary<string, double>[_weights.Length];
            for (int i = 0; i < _weights.Length; i++) rawByFactor[i] = new Dictionary<string, double>();

            var candidates = new List<string>();
            foreach (var pair in _tradable.Keys)
            {
                var pBuf = _priceBuf[pair];
                if (pBuf.Count < _maxRequiredBars) continue;   // not warmed up yet

                var prices = pBuf.ToArray();
                bool allOk = true;
                {%- for f in factors %}
                if (!_f{{ f.factor_index }}States[pair].Compute(prices, out var raw{{ f.factor_index }})) { allOk = false; }
                {%- endfor %}
                if (!allOk) continue;
                {%- for f in factors %}
                rawByFactor[{{ f.factor_index }}][pair] = raw{{ f.factor_index }};
                {%- endfor %}
                candidates.Add(pair);
            }

            if (candidates.Count == 0) { Liquidate(); return; }

            // ── Step 2: per-factor cross-sectional z-score, then weighted composite ──
            var composite = new Dictionary<string, double>();
            for (int i = 0; i < _weights.Length; i++)
            {
                var vals = rawByFactor[i];
                double mean = vals.Values.Average();
                double var2 = vals.Values.Select(v => (v - mean) * (v - mean)).Average();
                double std = Math.Sqrt(Math.Max(var2, 1e-18));
                if (std < 1e-12) std = 1.0;   // all equal → contribute 0
                foreach (var pair in candidates)
                {
                    double z = (vals[pair] - mean) / std;
                    if (!composite.ContainsKey(pair)) composite[pair] = 0.0;
                    composite[pair] += _weights[i] * z;
                }
            }

            // ── Step 3: rank and pick baskets ──
            var ranked = candidates.OrderByDescending(s => composite[s]).ToList();
            int k = RankMode == "percent"
                ? Math.Max(1, (int)Math.Round(ranked.Count * RankValue / 100.0))
                : Math.Min((int)RankValue, ranked.Count / 2);

            var longSet = new HashSet<string>();
            var shortSet = new HashSet<string>();
            if (StrategyType == "long_only" || StrategyType == "neutral")
                foreach (var s in ranked.Take(k)) longSet.Add(s);
            if (StrategyType == "short_only" || StrategyType == "neutral")
                foreach (var s in ranked.AsEnumerable().Reverse().Take(k)) shortSet.Add(s);
            shortSet.ExceptWith(longSet);

            // ── Step 4: liquidate stale positions, then size new ones equally ──
            foreach (var h in Portfolio.Values.Where(h => h.Invested).ToList())
            {
                var hp = h.Symbol.Value.ToUpperInvariant();
                if (!longSet.Contains(hp) && !shortSet.Contains(hp))
                    Liquidate(h.Symbol);
            }

            int total = longSet.Count + shortSet.Count;
            if (total == 0) return;
            decimal lw = longSet.Count > 0 ? 1.0m / total : 0m;
            decimal sw = shortSet.Count > 0 ? -1.0m / total : 0m;
            foreach (var s in longSet)  SetHoldings(_tradable[s], lw);
            foreach (var s in shortSet) SetHoldings(_tradable[s], sw);

            Log($"[REBALANCE] {Time:yyyy-MM-dd} candidates={candidates.Count} k={k} long={longSet.Count} short={shortSet.Count}");
        }

