        private static double ParseOptionalDouble(string[] csv, int idx)
        {
            if (csv.Length <= idx) return double.NaN;
            if (!double.TryParse(csv[idx], NumberStyles.Float, CultureInfo.InvariantCulture, out var v))
                return double.NaN;
            return v <= CoinglassSentinel + 1.0 ? double.NaN : v;
        }

        public override DateTime EndTime { get; set; }

        public override SubscriptionDataSource GetSource(SubscriptionDataConfig config, DateTime date, bool isLiveMode)
        {
            if (!string.IsNullOrWhiteSpace(ExplicitCsvPath) && !Directory.Exists(ExplicitCsvPath))
                return new SubscriptionDataSource(ExplicitCsvPath, Transport, FileFormat.Csv);

            if (!string.IsNullOrWhiteSpace(CustomDataRoot))
            {
                var symbolLower = config.Symbol.Value.ToLowerInvariant();
                var sliceKey = GetSliceKey(date, config.Resolution);
                var zipPath = Path.Combine(CustomDataRoot, ResolutionFolder, symbolLower, $"{sliceKey}_{EntrySuffix}.zip");
                var entryName = $"{sliceKey}_{symbolLower}_{ResolutionFolder}.csv";
                return new SubscriptionDataSource($"{zipPath}#{entryName}", SubscriptionTransportMedium.LocalFile, FileFormat.Csv);
            }

            var sym = config.Symbol.Value;
            var path = DataSourceTemplate.Replace("{symbol}", sym).Replace("{symbol_lower}", sym.ToLowerInvariant());
            return new SubscriptionDataSource(path, Transport, FileFormat.Csv);
        }

        private static string GetSliceKey(DateTime date, Resolution resolution) =>
            resolution switch
            {
                Resolution.Daily => date.ToString("yyyyMM", CultureInfo.InvariantCulture),
                _ => date.ToString("yyyyMMdd", CultureInfo.InvariantCulture),
            };

        public override bool RequiresMapping() => false;
        public override bool IsSparseData() => false;
        public override DateTimeZone DataTimeZone() => TimeZones.Utc;
        public override Resolution DefaultResolution() => Resolution.Daily;
        public override List<Resolution> SupportedResolutions() => new List<Resolution> { Resolution.Minute, Resolution.Hour, Resolution.Daily };

        public override BaseData Reader(SubscriptionDataConfig config, string line, DateTime date, bool isLiveMode)
        {
            if (string.IsNullOrWhiteSpace(line) || line.StartsWith("open") || line.StartsWith("\"")) return null;
            var csv = line.Split(',');
            if (csv.Length < 6) return null;
            try
            {
                var tsMs = long.Parse(csv[0], CultureInfo.InvariantCulture);
                var time = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddMilliseconds(tsMs);
                var takerBuyQuote  = csv.Length > 8 ? double.Parse(csv[8], CultureInfo.InvariantCulture) : 0.0;
                var takerSellQuote = csv.Length > 9 ? double.Parse(csv[9], CultureInfo.InvariantCulture) : 0.0;
                var bar = new FactorCsvBar
                {
                    Symbol = config.Symbol,
                    Time   = time,
                    EndTime = time + BarSpan,
                    Open   = decimal.Parse(csv[1], CultureInfo.InvariantCulture),
                    High   = decimal.Parse(csv[2], CultureInfo.InvariantCulture),
                    Low    = decimal.Parse(csv[3], CultureInfo.InvariantCulture),
                    Close  = decimal.Parse(csv[4], CultureInfo.InvariantCulture),
                    Volume = decimal.Parse(csv[5], CultureInfo.InvariantCulture),
                    TakerBuyVolume       = csv.Length > 6  ? double.Parse(csv[6],  CultureInfo.InvariantCulture) : 0.0,
                    TakerSellVolume      = csv.Length > 7  ? double.Parse(csv[7],  CultureInfo.InvariantCulture) : 0.0,
                    TakerBuyQuoteVolume  = takerBuyQuote,
                    TakerSellQuoteVolume = takerSellQuote,
                    TakerBuyTrades       = csv.Length > 10 ? double.Parse(csv[10], CultureInfo.InvariantCulture) : 0.0,
                    TakerSellTrades      = csv.Length > 11 ? double.Parse(csv[11], CultureInfo.InvariantCulture) : 0.0,
                    QuoteVolume          = takerBuyQuote + takerSellQuote,
                    // ── 1d 追加列 (csv[12..34]); 老 zip 列数不足时返回 NaN ──
                    OpenInterestOpen              = ParseOptionalDouble(csv, 12),
                    OpenInterestHigh              = ParseOptionalDouble(csv, 13),
                    OpenInterestLow               = ParseOptionalDouble(csv, 14),
                    OpenInterestClose             = ParseOptionalDouble(csv, 15),
                    FundingRateOpen               = ParseOptionalDouble(csv, 16),
                    FundingRateHigh               = ParseOptionalDouble(csv, 17),
                    FundingRateLow                = ParseOptionalDouble(csv, 18),
                    FundingRateClose              = ParseOptionalDouble(csv, 19),
                    GlobalAccountLongPercent      = ParseOptionalDouble(csv, 20),
                    GlobalAccountShortPercent     = ParseOptionalDouble(csv, 21),
                    GlobalAccountLongShortRatio   = ParseOptionalDouble(csv, 22),
                    TopPositionLongPercent        = ParseOptionalDouble(csv, 23),
                    TopPositionShortPercent       = ParseOptionalDouble(csv, 24),
                    TopPositionLongShortRatio     = ParseOptionalDouble(csv, 25),
                    TopAccountLongPercent         = ParseOptionalDouble(csv, 26),
                    TopAccountShortPercent        = ParseOptionalDouble(csv, 27),
                    TopAccountLongShortRatio      = ParseOptionalDouble(csv, 28),
                    LiquidationLongUsd            = ParseOptionalDouble(csv, 29),
                    LiquidationShortUsd           = ParseOptionalDouble(csv, 30),
                    BinancePremiumIndexOpen       = ParseOptionalDouble(csv, 31),
                    BinancePremiumIndexHigh       = ParseOptionalDouble(csv, 32),
                    BinancePremiumIndexLow        = ParseOptionalDouble(csv, 33),
                    BinancePremiumIndexClose      = ParseOptionalDouble(csv, 34),
                };
                bar.Value = bar.Close;
                return bar;
            }
            catch { return null; }
        }
    }

    public class {{ class_name }} : QCAlgorithm
    {
        // ── Composite weights (one per factor) ──
        private static readonly double[] _weights = new double[] { {{ weights|join(", ") }} };

        // ── Selection rule ──
        private const string RankMode = "{{ rank_mode }}";          // "N" or "percent"
        private const double RankValue = {{ rank_value }};
        private const string StrategyType = "{{ strategy_type }}";   // long_only / short_only / neutral
        private const int RebalanceBars = {{ rebalance_bars }};

        // ── All symbols (union of daily snapshots) ──
        private static readonly string[] AllSymbols = new string[] {
            {%- for s in all_symbols %}
            "{{ s }}"{% if not loop.last %},{% endif %}
            {%- endfor %}
        };

        // ── Daily universe plan: yyyy-MM-dd → list of TOKEN names (uppercase base) ──
        private static readonly Dictionary<string, HashSet<string>> _dailyUniverse = BuildDailyUniverse();

        private static Dictionary<string, HashSet<string>> BuildDailyUniverse()
        {
            var dict = new Dictionary<string, HashSet<string>>();
            {%- for date, tokens in daily_plan_items %}
            dict["{{ date }}"] = new HashSet<string> { {% for t in tokens %}"{{ t }}"{% if not loop.last %}, {% endif %}{% endfor %} };
            {%- endfor %}
            return dict;
        }

        // Map Symbol → token (uppercase, no usdt suffix) so we can intersect with universe
        private readonly Dictionary<Symbol, string> _symbolToToken = new Dictionary<Symbol, string>();
        // Per-symbol close-price ring buffer
        private readonly Dictionary<Symbol, Queue<double>> _priceBuf = new Dictionary<Symbol, Queue<double>>();

        // ── Factor states (one Dictionary<Symbol, State> per factor) ──
        {%- for f in factors %}
        private readonly Dictionary<Symbol, FactorState_F{{ f.factor_index }}> _f{{ f.factor_index }}States = new Dictionary<Symbol, FactorState_F{{ f.factor_index }}>();
        {%- endfor %}

        private int _barsSinceRebalance = 0;
        private int _maxRequiredBars = 1;

        public override void Initialize()
        {
            SetStartDate({{ start_year }}, {{ start_month }}, {{ start_day }});
            SetEndDate({{ end_year }}, {{ end_month }}, {{ end_day }});
            SetCash({{ initial_cash }});
            SetTimeZone(TimeZones.Utc);

            // ── FactorCsvBar configuration (CustomDataRoot is injected by match worker) ──
            var resolutionStr = "{{ lean_resolution }}";
            FactorCsvBar.ResolutionFolder = "{{ resolution_folder }}";
            FactorCsvBar.BarSpan = TimeSpan.FromHours({{ bar_hours }});
            FactorCsvBar.Transport = SubscriptionTransportMedium.LocalFile;
            FactorCsvBar.CustomDataRoot = GetParameter("custom-data-root", "").Trim();
            FactorCsvBar.DataSourceTemplate = GetParameter("custom-data-template", "").Trim();
            FactorCsvBar.ExplicitCsvPath = GetParameter("csv-path", "").Trim();

            var resolution = Resolution.{{ lean_resolution }};

            // ── Initialize per-factor required-bar counts (taken from PRICE_WINDOW_EXPR
            //    of each factor; we compute them in temp instances to find max).
            {%- for f in factors %}
            {
                var s = new FactorState_F{{ f.factor_index }}();
                s.InitParams(this);
                _maxRequiredBars = Math.Max(_maxRequiredBars, s.RequiredBars());
            }
            {%- endfor %}

            // ── Subscribe to every symbol that appears in any daily snapshot ──
            foreach (var sym in AllSymbols)
            {
                var added = AddData<FactorCsvBar>(sym, resolution);
                var leanSymbol = added.Symbol;
                _symbolToToken[leanSymbol] = TokenFromPair(sym);
                _priceBuf[leanSymbol] = new Queue<double>();
                {%- for f in factors %}
                {
                    var s = new FactorState_F{{ f.factor_index }}();
                    s.InitParams(this);
                    _f{{ f.factor_index }}States[leanSymbol] = s;
                }
                {%- endfor %}
            }

            // Warm-up: max factor lookback + a small buffer.
            var warmupBars = _maxRequiredBars + 5;
            SetWarmUp(warmupBars * FactorCsvBar.BarSpan);

            Log($"[INIT] {{ class_name }} factors={{ factors|length }} symbols={AllSymbols.Length} " +
                $"weights=[{string.Join(",", _weights)}] rankMode={RankMode} rankValue={RankValue} " +
                $"strategyType={StrategyType} rebalanceBars={RebalanceBars} warmupBars={warmupBars}");
            {%- for f in factors %}
            Log("[INIT] factor#{{ f.factor_index }} type={{ f.factor_type }} formula={{ f.factor_formula }}");
            {%- endfor %}
        }

        private static string TokenFromPair(string pair)
        {
            // "btcusdt" → "BTC", "1000pepeusdt" → "1000PEPE"
            var upper = pair.ToUpperInvariant();
            return upper.EndsWith("USDT") ? upper.Substring(0, upper.Length - 4) : upper;
        }

        public override void OnData(Slice slice)
        {
            // Update per-symbol price + factor state for every bar that arrived this tick
            foreach (var kv in slice.Get<FactorCsvBar>())
            {
                var sym = kv.Key;
                var bar = kv.Value;
                if (!_priceBuf.ContainsKey(sym)) continue;

                var pBuf = _priceBuf[sym];
                pBuf.Enqueue((double)bar.Close);
                if (pBuf.Count > _maxRequiredBars) pBuf.Dequeue();

                {%- for f in factors %}
                if (_f{{ f.factor_index }}States.TryGetValue(sym, out var st{{ f.factor_index }}))
                    st{{ f.factor_index }}.UpdateBar(bar, _maxRequiredBars);
                {%- endfor %}
            }

            if (IsWarmingUp) return;

            _barsSinceRebalance++;
            if (_barsSinceRebalance < RebalanceBars) return;
            _barsSinceRebalance = 0;

            Rebalance();
        }

        private HashSet<string> CurrentUniverseTokens()
        {
            var key = Time.Date.ToString("yyyy-MM-dd");
            if (_dailyUniverse.TryGetValue(key, out var tokens)) return tokens;
            // Fall back to most recent snapshot ≤ today
            string bestKey = null;
            foreach (var k in _dailyUniverse.Keys)
                if (string.CompareOrdinal(k, key) <= 0 && (bestKey == null || string.CompareOrdinal(k, bestKey) > 0))
                    bestKey = k;
            return bestKey != null ? _dailyUniverse[bestKey] : new HashSet<string>();
        }

        private void Rebalance()
        {
            var todayTokens = CurrentUniverseTokens();
            if (todayTokens.Count == 0) return;

            // ── Step 1: collect raw factor signals for every candidate symbol ──
            //   rawByFactor[i] : Dictionary<Symbol, double>   (NaN → drop later)
            var rawByFactor = new Dictionary<Symbol, double>[_weights.Length];
            for (int i = 0; i < _weights.Length; i++) rawByFactor[i] = new Dictionary<Symbol, double>();

            var candidates = new List<Symbol>();
            foreach (var (sym, token) in _symbolToToken)
            {
                if (!todayTokens.Contains(token)) continue;
                var pBuf = _priceBuf[sym];
                if (pBuf.Count < _maxRequiredBars) continue;   // not warmed up yet

                var prices = pBuf.ToArray();
                bool allOk = true;
                {%- for f in factors %}
                if (!_f{{ f.factor_index }}States[sym].Compute(prices, out var raw{{ f.factor_index }})) { allOk = false; }
                {%- endfor %}
                if (!allOk) continue;
                {%- for f in factors %}
                rawByFactor[{{ f.factor_index }}][sym] = raw{{ f.factor_index }};
                {%- endfor %}
                candidates.Add(sym);
            }

            if (candidates.Count == 0) { Liquidate(); return; }

            // ── Step 2: per-factor cross-sectional z-score, then weighted composite ──
            var composite = new Dictionary<Symbol, double>();
            for (int i = 0; i < _weights.Length; i++)
            {
                var vals = rawByFactor[i];
                double mean = vals.Values.Average();
                double var2 = vals.Values.Select(v => (v - mean) * (v - mean)).Average();
                double std = Math.Sqrt(Math.Max(var2, 1e-18));
                if (std < 1e-12) std = 1.0;   // all equal → contribute 0
                foreach (var sym in candidates)
                {
                    double z = (vals[sym] - mean) / std;
                    if (!composite.ContainsKey(sym)) composite[sym] = 0.0;
                    composite[sym] += _weights[i] * z;
                }
            }

            // ── Step 3: rank and pick baskets ──
            var ranked = candidates.OrderByDescending(s => composite[s]).ToList();
            int k = RankMode == "percent"
                ? Math.Max(1, (int)Math.Round(ranked.Count * RankValue / 100.0))
                : Math.Min((int)RankValue, ranked.Count / 2);

            var longSet = new HashSet<Symbol>();
            var shortSet = new HashSet<Symbol>();
            if (StrategyType == "long_only" || StrategyType == "neutral")
                foreach (var s in ranked.Take(k)) longSet.Add(s);
            if (StrategyType == "short_only" || StrategyType == "neutral")
                foreach (var s in ranked.AsEnumerable().Reverse().Take(k)) shortSet.Add(s);
            shortSet.ExceptWith(longSet);

            // ── Step 4: liquidate stale positions, then size new ones equally ──
            foreach (var h in Portfolio.Values.Where(h => h.Invested).ToList())
                if (!longSet.Contains(h.Symbol) && !shortSet.Contains(h.Symbol))
                    Liquidate(h.Symbol);

            int total = longSet.Count + shortSet.Count;
            if (total == 0) return;
            decimal lw = longSet.Count > 0 ? 1.0m / total : 0m;
            decimal sw = shortSet.Count > 0 ? -1.0m / total : 0m;
            foreach (var s in longSet)  SetHoldings(s, lw);
            foreach (var s in shortSet) SetHoldings(s, sw);

            Log($"[REBALANCE] {Time:yyyy-MM-dd} candidates={candidates.Count} k={k} long={longSet.Count} short={shortSet.Count}");
        }

